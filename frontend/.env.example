# Database (Docker Compose defaults)
DATABASE_URL=postgresql://financeuser:financepass@localhost:5433/finance_db
# Production example:
# DATABASE_URL=postgresql://financeuser:financepass@db:5432/finance_db?sslmode=require

# Public app URL (single source of truth)
APP_URL=http://localhost:8080

# BetterAuth
BETTER_AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Optional application-layer encryption (recommended for production).
# Use a 32-byte key encoded as base64 or hex.
# DATA_ENCRYPTION_KEY_CURRENT=
# DATA_ENCRYPTION_KEY_PREVIOUS=
# DATA_ENCRYPTION_KEY_ID=k1

# Backend API
BACKEND_API_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Public demo login prefill (used by /login?demo=1)
NEXT_PUBLIC_DEMO_EMAIL=
NEXT_PUBLIC_DEMO_PASSWORD=

# Auth API rate limiting (frontend /api/auth proxy)
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_ATTEMPTS_PER_WINDOW=30
# Optional stricter limits for shared demo account sign-in
DEMO_AUTH_RATE_LIMIT_MAX_ATTEMPTS_PER_WINDOW=10
DEMO_AUTH_RATE_LIMIT_GLOBAL_MAX_ATTEMPTS_PER_WINDOW=120
